{
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1"
  },
  "scripts": {
    "test-ui": "npx playwright test --project=api",
    "test-api": "npx playwright test --project=api",
